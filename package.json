{
  "name": "@finktech/mcp-verify",
  "version": "1.0.0",
  "private": false,
  "description": "Enterprise-grade security validation and testing tool for MCP servers (Model Context Protocol)",
  "workspaces": [
    "libs/*",
    "apps/*"
  ],
  "main": "dist/mcp-verify.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-verify": "dist/mcp-verify.js",
    "mcp-verify-server": "dist/mcp-server.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.map",
    "!dist/.sea/**",
    "!dist/bin/**",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "QUICKSTART.md",
    "RESPONSIBLE_USAGE.md",
    "SECURITY_TESTING.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "AI_DEVELOPMENT.md",
    "API_REFERENCE.md",
    "ARCHITECTURE.md",
    "CODE_MAP.md",
    "COMMANDS.md",
    "DEVELOPMENT.md",
    "GLOSSARY.md",
    "REGRESSION-DETECTION.md",
    "RELEASE_NOTES.md",
    "SECURITY_SCORING.md",
    "TESTING.md",
    "TROUBLESHOOTING.md"
  ],
  "dependencies": {
    "acorn": "^8.15.0",
    "acorn-walk": "^8.3.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "ajv-i18n": "^4.2.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "eventsource": "^2.0.2",
    "i18next": "^25.8.0",
    "inquirer": "^13.3.0",
    "ora": "^7.0.0",
    "shell-quote": "^1.8.3",
    "update-notifier": "^7.3.1",
    "zod": "^4.3.6"
  },
  "scripts": {
    "dev": "ts-node apps/cli-verifier/src/bin/index.ts",
    "start": "node dist/mcp-verify.js",
    "build": "tsc --emitDeclarationOnly --outDir dist --project tsconfig.build.json && node tools/scripts/bundle.js",
    "compile": "node tools/scripts/compile-sea.js",
    "compile:all": "node tools/scripts/compile-sea.js --all",
    "compile:linux": "node tools/scripts/compile-sea.js --target linux",
    "compile:macos": "node tools/scripts/compile-sea.js --target macos",
    "compile:win": "node tools/scripts/compile-sea.js --target windows",
    "compile:server": "node tools/scripts/compile-sea.js --server",
    "postcompile": "node tools/scripts/copy-native-addons.js",
    "type-check": "tsc --noEmit --project tsconfig.build.json",
    "type-check:strict": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.js --max-warnings 1000",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "test": "jest",
    "test:unit": "jest --testPathPattern=\\.unit\\.test\\.ts$",
    "test:integration": "jest --testPathPattern=\\.integration\\.test\\.ts$",
    "test:e2e": "jest --testPathPattern=\\.e2e\\.test\\.ts$",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "preview:report": "ts-node tools/scripts/generate-report-preview.ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky install || true"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "security",
    "security-audit",
    "security-testing",
    "vulnerability-scanner",
    "validation",
    "testing",
    "fuzzing",
    "penetration-testing",
    "json-rpc",
    "cli",
    "ai",
    "llm",
    "claude",
    "anthropic",
    "owasp",
    "owasp-top-10",
    "enterprise",
    "devsecops",
    "appsec"
  ],
  "author": {
    "name": "Ariel Fink",
    "email": "hello.finksystems@gmail.com",
    "url": "https://github.com/FinkTech"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FinkTech/mcp-verify.git"
  },
  "bugs": {
    "url": "https://github.com/FinkTech/mcp-verify/issues"
  },
  "homepage": "https://github.com/FinkTech/mcp-verify#readme",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/update-notifier": "^6.0.8",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.27.2",
    "esbuild-plugin-tsconfig-paths": "^1.0.2",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-security": "^1.7.1",
    "husky": "^8.0.3",
    "jest": "^29.0.0",
    "lint-staged": "^15.0.0",
    "postject": "^1.0.0-alpha.6",
    "prettier": "^3.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "openai": "^6.17.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
