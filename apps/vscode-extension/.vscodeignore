# VSCode Extension Package Exclusions
# Files and folders excluded from the .vsix package

# Source files (already bundled into dist/extension.js)
src/**
tsconfig.json
.eslintrc.json
tsconfig.build.json

# Development dependencies
node_modules/**

# Tests
**/*.test.ts
**/*.spec.ts
**/__tests__/**
test/**
tests/**
*.test.js
*.spec.js

# Build artifacts
*.map
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE and editor files
.vscode/**
!.vscode/launch.json
!.vscode/tasks.json
.idea/**
*.swp
*.swo
*~

# Version control
.git/**
.gitignore
.gitattributes

# CI/CD
.github/**
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Documentation (keep README.md and CHANGELOG.md)
docs/**
*.md
!README.md
!CHANGELOG.md

# Package management
package-lock.json
yarn.lock
pnpm-lock.yaml
.npmrc
.yarnrc

# Environment files
.env
.env.*
*.env

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
tmp/**
temp/**
*.tmp
*.temp

# Coverage and test reports
coverage/**
.nyc_output/**
test-results/**
junit.xml

# Misc
*.vsix
webpack.config.js
.prettierrc
.editorconfig
