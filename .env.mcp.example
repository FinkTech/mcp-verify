# Guía de Variables para Servidores MCP

# --- Productividad & Otros ---
N8N_API_KEY="tu_api_key_aqui"
GITHUB_TOKEN="tu_github_pat_aqui"
GCP_PROJECT_ID="tu_id_de_proyecto"
NOTION_TOKEN="secret_tu_token_de_integracion"
GOOGLE_CREDENTIALS="C:\path\to\credentials.json"

# --- Diseño & Visual ---
FIGMA_TOKEN="figd_tu_token_aqui"
UNSPLASH_KEY="tu_access_key_aqui"
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
LOTTIEFILES_TOKEN="tu_token_aqui"

# --- Infraestructura & Backend ---
VERCEL_TOKEN="tu_vercel_token"
SUPABASE_URL="https://xyz.supabase.co"
SUPABASE_ANON_KEY="tu_anon_key"
GROQ_API_KEY="gsk_tu_key_aqui"
TRIGGER_API_KEY="tr_tu_key_aqui"

# --- Comunicación & Tareas ---
TELEGRAM_BOT_TOKEN="tu_bot_token_aqui"
DISCORD_BOT_TOKEN="tu_bot_token_aqui"
LINEAR_API_KEY="lin_api_tu_key_aqui"

# --- Públicos / Sin Key ---
# Lighthouse, Iconify, Google Fonts, Spline, Mermaid, Colors
