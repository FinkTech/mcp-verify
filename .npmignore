# NPM Package Exclusions
# Files and folders excluded from the npm package

# Source files (only compiled dist/ is needed)
apps/
libs/
tools/
tests/
config/

# TypeScript config
tsconfig*.json
.eslintrc.json
.prettierrc
.editorconfig

# Development files
*.ts
!*.d.ts
*.map

# Tests
**/*.test.ts
**/*.spec.ts
**/__tests__/**
test/**
*.test.js
*.spec.js
jest.config.js
coverage/

# Build scripts
tools/scripts/

# Development dependencies
node_modules/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Version control
.git/
.gitignore
.gitattributes
.github/

# CI/CD
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml
.circleci/

# Documentation (keep essential docs, exclude subdirectories)
docs/
guides/

# Include ALL root-level .md files (comprehensive documentation)
*.md
!README.md
!CHANGELOG.md
!SECURITY.md
!QUICKSTART.md
!RESPONSIBLE_USAGE.md
!SECURITY_TESTING.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!AI_DEVELOPMENT.md
!API_REFERENCE.md
!ARCHITECTURE.md
!CODE_MAP.md
!COMMANDS.md
!DEVELOPMENT.md
!GLOSSARY.md
!REGRESSION-DETECTION.md
!RELEASE_NOTES.md
!SECURITY_SCORING.md
!TESTING.md
!TROUBLESHOOTING.md

# Package management
package-lock.json
yarn.lock
pnpm-lock.yaml
.npmrc
.yarnrc

# Environment files
.env
.env.*
*.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS files
Thumbs.db
desktop.ini

# Misc
.husky/
.lint-staged
.archived/
test_full_results.txt
*.tape
action.yml
*.bat
*.config.json
*.config.example.json
*.example

# SEA build artifacts (not needed for npm package)
dist/.sea/
dist/bin/
**/*.map
*.map

# Keep only essential files in package:
# - dist/ (compiled code)
# - package.json
# - LICENSE
# - Root-level .md files (20 documentation files):
#   * README.md, CHANGELOG.md, SECURITY.md
#   * QUICKSTART.md, RESPONSIBLE_USAGE.md, SECURITY_TESTING.md
#   * CONTRIBUTING.md, CODE_OF_CONDUCT.md
#   * AI_DEVELOPMENT.md (AI dev guidance → points to repo for AGENTS.md/CLAUDE.md)
#   * API_REFERENCE.md, ARCHITECTURE.md, CODE_MAP.md
#   * COMMANDS.md, DEVELOPMENT.md, GLOSSARY.md
#   * REGRESSION-DETECTION.md, RELEASE_NOTES.md
#   * SECURITY_SCORING.md, TESTING.md, TROUBLESHOOTING.md
# Note: AGENTS.md and CLAUDE.md are excluded (reference source files not present in dist/)
