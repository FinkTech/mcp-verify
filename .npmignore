# NPM Package Exclusions
# Files and folders excluded from the npm package

# Source files (only compiled dist/ is needed)
apps/
libs/
tools/
tests/
config/

# TypeScript config
tsconfig*.json
.eslintrc.json
.prettierrc
.editorconfig

# Development files
*.ts
!*.d.ts
*.map

# Tests
**/*.test.ts
**/*.spec.ts
**/__tests__/**
test/**
*.test.js
*.spec.js
jest.config.js
coverage/

# Build scripts
tools/scripts/

# Development dependencies
node_modules/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Version control
.git/
.gitignore
.gitattributes
.github/

# CI/CD
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml
.circleci/

# Documentation (keep only README, LICENSE, CHANGELOG)
docs/
guides/
*.md
!README.md
!CHANGELOG.md

# Package management
package-lock.json
yarn.lock
pnpm-lock.yaml
.npmrc
.yarnrc

# Environment files
.env
.env.*
*.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Temporary files
tmp/
temp/
nuevo/
*.tmp
*.temp

# Landing and Agent Sandboxes
mcp-verify-landing/

# OS files
Thumbs.db
desktop.ini

# Misc
.husky/
.lint-staged
refactorizacion/
AGENTS/
300/
analisis.txt
ANALISIS_PROYECTO_REAL.md

# Keep only essential files in package:
# - dist/ (compiled code)
# - README.md
# - LICENSE
# - CHANGELOG.md
# - package.json
